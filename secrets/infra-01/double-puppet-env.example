# Template for secrets/infra-01/double-puppet-env.age (encrypt with agenix).
# Shared by mautrix-discord and mautrix-slack on infra-01.

# Synapse double-puppet shared secret (matches bridge config).
DOUBLE_PUPPET_SECRET=

# Stable mautrix-slack encryption key (do not use "generate" in production).
ENCRYPTION_PICKLE_KEY=

# mautrix-slack public media signing key (random base64, 32 bytes).
PUBLIC_MEDIA_SIGNING_KEY=

# mautrix-discord signed avatar proxy key (random base64, 32 bytes).
AVATAR_PROXY_KEY=

# mautrix-slack app relay login ID from `list-logins` after `login app` in @slack.
# Must match Forgejo secret MATRIX_SLACK_RELAY_LOGIN_ID / TF_VAR_matrix_slack_relay_login_id in governance.
SLACK_RELAY_LOGIN_ID=
