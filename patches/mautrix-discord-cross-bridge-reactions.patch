+func (portal *Portal) reactionSessionUser(sender *User) *User {
+	if sender != nil && sender.IsLoggedIn() && sender.Session != nil {
+		return sender
+	}
+	lookupID := portal.Key.ChannelID
+	if portal.GuildID != "" {
+		lookupID = portal.GuildID
+	}
+	for _, mxid := range portal.bridge.DB.GetUsersInPortal(lookupID) {
+		u := portal.bridge.GetUserByMXID(mxid)
+		if u != nil && u.IsLoggedIn() && u.Session != nil {
+			return u
+		}
+	}
+	return nil
+}
