+func (portal *Portal) roomPingRoleID() string {
+	if portal.GuildID == "" {
+		return ""
+	}
+	if roleID := portal.roomPingRoleFromOverwrites(); roleID != "" {
+		return roleID
+	}
+	for _, role := range portal.bridge.DB.Role.GetAll(portal.GuildID) {
+		if role.Name == "Tech" {
+			return role.ID
+		}
+	}
+	return ""
+}
+
+func (portal *Portal) roomPingRoleFromOverwrites() string {
+	user := portal.bridge.getLoggedInUserForPortal()
+	if user == nil || user.Session == nil {
+		return ""
+	}
+	channel, _ := user.Session.State.Channel(portal.Key.ChannelID)
+	if channel == nil {
+		var err error
+		channel, err = user.Session.Channel(portal.Key.ChannelID)
+		if err != nil {
+			return ""
+		}
+	}
+	var bestID string
+	var bestPos int
+	for _, ow := range channel.PermissionOverwrites {
+		if ow.Type != discordgo.PermissionOverwriteTypeRole {
+			continue
+		}
+		if ow.ID == portal.GuildID {
+			continue
+		}
+		if ow.Allow&discordgo.PermissionViewChannel == 0 {
+			continue
+		}
+		role := portal.bridge.DB.Role.GetByID(portal.GuildID, ow.ID)
+		if role == nil || role.Managed {
+			continue
+		}
+		if role.Position > bestPos {
+			bestPos = role.Position
+			bestID = ow.ID
+		}
+	}
+	return bestID
+}
