+func (portal *Portal) discordSessionForMatrixSender(sender *User, senderMXID id.UserID) (*User, *discordgo.Session) {
+	if sender.Session != nil {
+		return sender, sender.Session
+	}
+	if discordID := bridgeidentity.DiscordIDForMXID(senderMXID); discordID != "" {
+		u := portal.bridge.GetCachedUserByID(discordID)
+		if u == nil {
+			u = portal.bridge.GetUserByID(discordID)
+		}
+		if u != nil && u.Connected() {
+			return u, u.Session
+		}
+		portal.log.Warn().
+			Str("sender", senderMXID.String()).
+			Str("discord_id", discordID).
+			Bool("user_found", u != nil).
+			Bool("connected", u != nil && u.Connected()).
+			Msg("Linked Discord user not connected; using relay webhook")
+		return sender, nil
+	}
+	if slackUID := bridgeidentity.ParseSlackGhostUserID(senderMXID); slackUID != "" {
+		localpart := bridgeidentity.Get().MatrixLocalpartForSlack(slackUID)
+		portal.log.Info().
+			Str("sender", senderMXID.String()).
+			Str("slack_uid", slackUID).
+			Str("matrix_localpart", localpart).
+			Msg("Slack ghost outbound puppet lookup")
+		if localpart != "" {
+			mxid := id.NewUserID(strings.ToLower(localpart), portal.bridge.Config.Homeserver.Domain)
+			u := portal.bridge.GetCachedUserByMXID(mxid)
+			if u == nil {
+				u = portal.bridge.GetUserByMXID(mxid)
+			}
+			if u != nil && u.Connected() {
+				return u, u.Session
+			}
+			portal.log.Warn().
+				Str("sender", senderMXID.String()).
+				Str("matrix_localpart", localpart).
+				Str("matrix_mxid", mxid.String()).
+				Bool("user_found", u != nil).
+				Bool("connected", u != nil && u.Connected()).
+				Msg("Slack ghost linked to Matrix user but no connected Discord session; using relay webhook")
+			return sender, nil
+		}
+		portal.log.Warn().Str("sender", senderMXID.String()).Str("slack_uid", slackUID).Msg("Slack ghost has no linked identity; using relay webhook")
+	}
+	return sender, nil
+}
