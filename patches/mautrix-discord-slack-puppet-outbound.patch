+func (portal *Portal) discordSessionForMatrixSender(sender *User, senderMXID id.UserID) (*User, *discordgo.Session) {
+	if sender.Session != nil {
+		return sender, sender.Session
+	}
+	discordID := bridgeidentity.DiscordIDForMXID(senderMXID)
+	if discordID == "" {
+		return sender, nil
+	}
+	if u := portal.bridge.GetUserByID(discordID); u != nil && u.Connected() {
+		return u, u.Session
+	}
+	return sender, nil
+}
